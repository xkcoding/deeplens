# ── Phase 1: Anthropic (explore / generate) ──────

# Required: API Key
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Custom API base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic  # MiniMax example

# ── Phase 2: OpenRouter (index / serve / Q&A) ────

# Required for `deeplens index` and `deeplens serve`
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Custom base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Embedding model (default: qwen/qwen3-embedding-8b)
# OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b

# Optional: LLM model for search/Q&A (default: qwen/qwen3-32b)
# OPENROUTER_LLM_MODEL=qwen/qwen3-32b
