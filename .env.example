# ── Phase 1: Anthropic (explore / generate) ──────

# Required: API Key (either one)
ANTHROPIC_API_KEY=your_api_key_here
# ANTHROPIC_AUTH_TOKEN=your_token_here  # Alternative (e.g., MiniMax)

# Optional: Custom API base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic  # MiniMax example

# ── Phase 2: SiliconFlow (index / serve) ─────────

# Required for `deeplens index` and `deeplens serve`
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Optional: Custom base URL (default: https://api.siliconflow.cn/v1)
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Optional: Embedding model (default: Qwen/Qwen3-Embedding-8B, 2048 dims)
# SILICONFLOW_EMBED_MODEL=Qwen/Qwen3-Embedding-8B

# Optional: LLM model for search/investigate (default: deepseek-ai/DeepSeek-V3)
# SILICONFLOW_LLM_MODEL=deepseek-ai/DeepSeek-V3
